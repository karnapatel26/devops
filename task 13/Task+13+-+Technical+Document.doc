</tr>
<tr>
<td class=3D"confluenceTd">
<p local-id=3D"cb07d6206f92">Infrastructure</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"f713d70c635a">Deployment restricted to a single EC2 instance=
</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
