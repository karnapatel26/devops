<li local-id=3D"d0c47d1a6cf5">
<p local-id=3D"ae56dd676806">Provided ECR image URI</p></li>
<li local-id=3D"7e26ebf443e4">
<p local-id=3D"be07790ba511">Configured environment variables</p></li>
<li local-id=3D"9b6fff763bc3">
<p local-id=3D"4a44b668128b">Attached IAM role with:</p>
<ul local-id=3D"71117c40b37e">
<li local-id=3D"4dac98c0a6dc">
<p local-id=3D"c17dc8e02c11">SSM permissions</p></li>
<li local-id=3D"f2ca7f62e881">
<p local-id=3D"baaa143281fc">CloudWatch logging permissions</p></li>
</ul></li>
</ul>
