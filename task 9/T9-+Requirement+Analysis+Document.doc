<td data-local-id=3D"f3ad01f57eda" class=3D"confluenceTd">
<p local-id=3D"8511f7a6b937">Elastic Compute Cloud</p></td>
</tr>
<tr data-local-id=3D"2b867dda4f91">
<td data-local-id=3D"25e819017045" class=3D"confluenceTd">
<p local-id=3D"173b06288616">IAM</p></td>
<td data-local-id=3D"8a0c9a54dfdc" class=3D"confluenceTd">
