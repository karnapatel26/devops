&amp;api=3Dv2" data-height=3D"526" data-width=3D"965" data-unresolved-comme=
nt-count=3D"0" data-linked-resource-id=3D"1853161493" data-linked-resource-=
version=3D"1" data-linked-resource-type=3D"attachment" data-linked-resource=
-default-alias=3D"Untitled Diagram.drawio (11)-20260311-092110.png" data-ba=
se-url=3D"https://iamops.atlassian.net/wiki" data-linked-resource-content-t=
ype=3D"image/png" data-linked-resource-container-id=3D"1847165796" data-lin=
ked-resource-container-version=3D"3" data-media-id=3D"2e2dea54-f5d3-4eb0-84=
