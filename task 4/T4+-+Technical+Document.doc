nceTd">
<p local-id=3D"a3ba44aea78d">Identity</p></td>
<td data-local-id=3D"41591a71-60a2-4734-a468-f4cca20e41b8" class=3D"conflue=
nceTd">
<p local-id=3D"3ed28329453e">IAM Policies</p></td>
</tr>
<tr data-local-id=3D"dc18a183-a6ce-4a22-adf0-1400e0493649">
<td data-local-id=3D"21a1d2b3-cb12-496d-a43d-b4bb5d1b9101" class=3D"conflue=
nceTd">
<p local-id=3D"465d84b73937">Storage</p></td>
<td data-local-id=3D"ec0e702c-8166-4e50-b56b-e9d0773ea40f" class=3D"conflue=
