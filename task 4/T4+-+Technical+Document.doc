nceTd">
<p local-id=3D"3ffefd12593b">Compute</p></td>
<td data-local-id=3D"b6c6f261-c196-4508-85b5-be56ca06bd48" class=3D"conflue=
nceTd">
<p local-id=3D"b94f6f394122">Controlled EC2 Access</p></td>
</tr>
</tbody>
