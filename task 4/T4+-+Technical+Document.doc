<hr local-id=3D"fb240223-ae52-47de-8a24-8ea7257ea235">
<h2 local-id=3D"cdbd02de76ba" id=3D"T4-TechnicalDocument-7.5SecuritySummary=
">7.5 Security Summary</h2>
<p local-id=3D"b3a80646a60e">The solution demonstrates layered security con=
trols across:</p>
<div class=3D"table-wrap">
<table data-table-width=3D"760" data-layout=3D"default" data-local-id=3D"b9=
19b782-17f6-4742-9be3-b1dbd08fc2b4" class=3D"confluenceTable">
<tbody>
<tr data-local-id=3D"add567fb-2607-4783-a164-ab9955ade267">
<th data-local-id=3D"f8653b7c-56ad-4dd8-9fd9-aced66a78d64" class=3D"conflue=
nceTh">
<p local-id=3D"a04a9a0bd8be">Layer</p></th>
<th data-local-id=3D"223862d5-8a8b-4072-af8e-d1ea5e041cea" class=3D"conflue=
nceTh">
<p local-id=3D"c6460094bc8d">Security Mechanism</p></th>
</tr>
<tr data-local-id=3D"11da594d-5894-42d9-a43b-a99bb5c4c245">
<td data-local-id=3D"ce99ccb2-84cf-4cde-8769-d79b0c34f252" class=3D"conflue=
nceTd">
<p local-id=3D"401b805427b5">Network</p></td>
