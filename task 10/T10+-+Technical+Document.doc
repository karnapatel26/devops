<th class=3D"confluenceTh">
<p local-id=3D"56a57c972a5f">Visualization</p></th>
</tr>
<tr>
<td class=3D"confluenceTd">
<p local-id=3D"2047ae687dd5">CPU Utilization</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"461fdd317483">Line Chart</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
