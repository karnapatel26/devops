<td class=3D"confluenceTd">
<p local-id=3D"6a91d5211d91">$0.40/million queries (low volume)</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p local-id=3D"a2bd4bcb0504">EC2 Data Transfer</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"fe7838c1b891">DNS response traffic</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"c259f9b12e10">~$0.50</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"361edbccec2e">Minimal for DNS-only workload</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
