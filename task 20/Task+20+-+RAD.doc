<p local-id=3D"f1a72aaa0ad1">Dependency</p></th>
<th class=3D"confluenceTh">
<p local-id=3D"70ef7e6f640e">Purpose</p></th>
</tr>
<tr>
<td class=3D"confluenceTd">
<p local-id=3D"736113295f8f">AWS EC2</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"0ff36a3630fd">Hosts the BIND9 DNS server</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p local-id=3D"834cfb91b76c">AWS Route 53</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"530228390fc2">Managed DNS hosted zone for the domain</p></td=
>
</tr>
<tr>
