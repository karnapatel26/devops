<h2 local-id=3D"71758f2f6627" id=3D"Task22-RAD-6.RiskAnalysis">6. Risk Anal=
ysis</h2>
<h3 local-id=3D"ac35c75e5902" id=3D"Task22-RAD-6.1RiskIdentification">6.1 R=
isk Identification</h3>
<div class=3D"table-wrap">
<table data-table-width=3D"760" data-layout=3D"default" data-local-id=3D"1a=
a38ac5-9e6f-4c0b-8f86-dd9e3850e1ee" class=3D"confluenceTable">
<tbody>
<tr>
<th class=3D"confluenceTh">
<p local-id=3D"b684948d1144">Risk ID</p></th>
<th class=3D"confluenceTh">
<p local-id=3D"f933b5e47344">Risk Description</p></th>
<th class=3D"confluenceTh">
<p local-id=3D"7e5fa8368de8">Likelihood</p></th>
<th class=3D"confluenceTh">
<p local-id=3D"2f34d03f87ae">Impact</p></th>
</tr>
<tr>
<td class=3D"confluenceTd">
<p local-id=3D"403c86caa83b">R1</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"7fe070fbb7cc">EC2 instance has insufficient RAM causing GitL=
ab CE to crash or fail to start</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"e89e1bb46171">Medium</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"1651275d1ed6">High</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p local-id=3D"da076837b081">R2</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"4f9e2e2a8149">Security Group misconfiguration blocking web a=
ccess to GitLab CE</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"34a4bbff55bb">Medium</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"ae268ec7500a">High</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p local-id=3D"d97fc907b770">R3</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"784c46f12861">Initial root password file expires or is missi=
ng before first login</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"91032c5f67c3">Low</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"7385f143db52">High</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p local-id=3D"258b463369bf">R4</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"f5e958ba2ebb">Git push fails due to authentication error (wr=
ong credentials or PAT not configured)</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"567c14073853">Medium</p></td>
<td class=3D"confluenceTd">
<p local-id=3D"c81ce74075c0">Medium</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
